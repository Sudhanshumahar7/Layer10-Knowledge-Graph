# Layer10 - Root .env example

# 1. Pipeline Authentication
# Required to fetch issues from LangChain repo if you exceed rate limits or want to ingest other repos.
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# 2. LLM Extraction
# Required to run pipeline/extract.py to Identifty entities and relationships.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
